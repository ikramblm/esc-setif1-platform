# ── Server ──────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:admin123@localhost:5432/esc_setif1

# ── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET_ACCESS_64CHARS
JWT_REFRESH_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET_REFRESH_64CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Encryption (AES-256) ─────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_AES_KEY_EXACTLY!

# ── CORS ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email (SMTP) ─────────────────────────────────────
# Gmail: host=smtp.gmail.com, port=587, user=your address, pass=16-char App Password (not your normal password)
# Leave unset to fall back to console-logged devCode (dev mode only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=CHANGE_ME_GMAIL_APP_PASSWORD
SMTP_FROM=ESC Sétif 1 <your.email@gmail.com>

# ── Rate limiting ────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=10
